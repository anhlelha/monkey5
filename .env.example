# Copy to .env.local and fill in.

AUTH_SECRET=replace-me-with-32-bytes-base64

# REQUIRED in production: set to `true` when behind a reverse proxy or custom
# domain. Prevents Auth.js `UntrustedHost` errors. Safe to leave in dev too.
AUTH_TRUST_HOST=true

# Optional: explicit NextAuth callback base URL. The deploy script
# (scripts/deploy.sh) automatically rewrites this to `http://<VM_IP>:3000`
# on the VM during deploy. Only set here if you need a different base.
# NEXTAUTH_URL=http://localhost:3000


# Google OAuth (optional — Demo credentials provider works without these).
# Create at https://console.cloud.google.com/apis/credentials
#   Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated emails that get the admin role on first sign-in.
ADMIN_EMAILS=anhlh48@fpt.com

# SQLite DB lives at prisma/dev.db by default; overrideable here.
# DATABASE_URL="file:./dev.db"

# Google Gemini API key — only needed by scripts/draw-figure-gemini.sh (slash
# command /exam-import → Workflow D). Get at https://aistudio.google.com/app/apikey.
# Free tier is enough; gemini-2.5-flash-lite gives 1500 RPD. Not required to
# run the app, only when generating new figure SVGs.
# GEMINI_API_KEY=

# OpenAI API key — only needed by scripts/draw-figure-codex.sh (Codex CLI
# default engine for figure generation; Gemini is the fallback). Get at
# https://platform.openai.com/api-keys. Not required to run the app.
# OPENAI_API_KEY=
